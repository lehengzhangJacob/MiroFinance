# API keys & tokens (keep locally only)
*_key
tushare_token
.env
.env.*
!MiroMemSkill/.env.template

# Conda exported requirements (regenerate via deploy/conda/setup_*.sh)
deploy/conda/requirements-*.txt

# Runtime logs (nohup pool3, hermes evolve, etc.)
deploy/logs/
logs/

# Course archives (local reference only)
*.7z

# MiroMemSkill runtime memory (skills/*.md and skills_ashare/*.md stay tracked)
MiroMemSkill/memory_bank/*.jsonl
MiroMemSkill/memory_bank/*.bak*
MiroMemSkill/memory_bank/*.lock
MiroMemSkill/memory_bank/*.db
MiroMemSkill/memory_bank/*.db-*
MiroMemSkill/.memory_archives/
MiroMemSkill/.runtime/
MiroMemSkill/logs/

# Packaged-skill run artifacts (qlib_skill outputs etc.)
MiroMemSkill/memory_bank/skills_ashare/*/outputs/

# External reference clones / separate remotes (do not nest in MiroFinance)
Mem0/
# report/ tracked in-repo (midterm plan, ACL templates)

# Hermes validation runtime logs
hermes-agent-self-evolution_validation/logs/
hermes-agent-self-evolution/.venv/
hermes-agent-self-evolution/logs/
hermes-agent-self-evolution/output/
hermes-agent-self-evolution/.pytest_cache/
hermes-agent-self-evolution/*.egg-info/
hermes-agent-self-evolution/datasets/**/*.jsonl

# Python / runtime
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# MiroFlow runtime artifacts (see also MiroFlow/.gitignore)
MiroFlow/logs/
MiroFlow/.venv/
